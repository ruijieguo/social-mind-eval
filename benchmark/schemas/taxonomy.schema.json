{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "social-mind-benchmark/taxonomy.schema.json",
  "title": "Social Mind Taxonomy",
  "description": "Schema for the machine-readable social mind evaluation taxonomy.",
  "$defs": {
    "capability": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"}
      },
      "additionalProperties": false
    },
    "subdimension": {
      "type": "object",
      "required": ["id", "name", "task_family", "capabilities"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "task_family": {"type": "string", "enum": ["T1", "T2", "T3", "T4", "T5", "T6"]},
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/capability"}
        }
      },
      "additionalProperties": false
    },
    "dimension": {
      "type": "object",
      "required": ["id", "name", "core_question", "subdimensions"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "core_question": {"type": "string"},
        "subdimensions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/subdimension"}
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": ["version", "name", "description", "dimensions"],
  "properties": {
    "version": {"type": ["string", "number"]},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/dimension"}
    }
  },
  "additionalProperties": false
}
